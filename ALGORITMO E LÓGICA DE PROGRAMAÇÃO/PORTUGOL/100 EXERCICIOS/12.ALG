Algoritmo "semnome"

// 12) Crie um programa que leia o preþo de um produto, calcule e mostre o seu
// PREÃO PROMOCIONAL, com 5% de desconto.

Var

   preco: real
   precodesconto: real
Inicio

      Escreval("Digite o preþo do produto: ")
      leia(preco)
      
      precodesconto <- preco - (preco*0.05)
      Escreval("O preþo promocional com 5% de desconto do pruduto Ú: ", precodesconto:0:2)

Fimalgoritmo