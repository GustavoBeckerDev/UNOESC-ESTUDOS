Algoritmo "Algoritmo 20"

// 20) Desenvolva um programa que leia um número inteiro e mostre se ele é PAR ou
// ÍMPAR.

Var

   n: inteiro

Inicio

      Escreva("Digite um número inteiro: ")
      leia(n)

      Se (n mod 2 = 1) Entao
         Escreval("O número ", n, " é ímpar!")
      Senao
         Escreval("O número ", n, " é par!")
      Fimse

Fimalgoritmo