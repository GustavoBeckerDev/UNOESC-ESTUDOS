Algoritmo "semnome"

// 13) FaÁa um algoritmo que leia o sal·rio de um funcion·rio, calcule e mostre o
// seu novo sal·rio, com 15% de aumento.

Var

   salario, novosalario: real

Inicio

      Escreva("Digite seu sal·rio atual: ")
      leia(salario)
      
      novosalario <- salario + (salario * 0.15)
      
      Escreval("Seu sal·rio com 15% de aumento ficar·: ", novosalario:0:2)

Fimalgoritmo